# Compiler files
cache/
out/
.gocache/

# Ignores development broadcast logs
!/broadcast
/broadcast/*/31337/
/broadcast/**/dry-run/

# Dotenv file
.env
*.env
.env*

# binary
ap-avs

.DS_Store
node_modules

# Ignores operator configuration files at root
operator.yaml
metadata.json

# Ignores yaml configuration files in the config directory.
# Whitelist the shared deployment configs that ship inside the Docker
# image (Railway + local dev). Operator-specific or per-user configs
# (e.g. `aggregator.yaml`, `operator.yaml`) stay ignored.
config/*.yaml
!config/aggregator.example.yaml
!config/operator.example.yaml
!config/*-dev.yaml
!config/*-railway.yaml
!config/*-rehearsal.yaml
# Snapshot of tracked configs taken before any restructure; safety net.
!config/_legacy/
!config/_legacy/*.yaml

contracts/script/output*

contracts/broadcast/
alias-ecdsa.key.json

keys/

# BadgerDB database files (runtime data)
cmd/data/
**/badger/
*.vlog
DISCARD
KEYREGISTRY
MANIFEST

# Plugin files for semantic release
.semrel/

# Log files
*.log
*_logs.txt
_aggregator-*.txt
_operator-*.txt
*.zip

# PR comment output files
pr-comments-*.json

# Environment files
.env.test
.env.local

# Claude Code settings (machine-local paths and user-specific permissions)
.claude/settings.json
.claude/settings.local.json

# Ignore the file/folder that is constantly added by Cursor
EigenLayer-AVS

# VS Code workspace files
*.code-workspace
# Hetzner donor snapshots + rehearsal scratch gateway DB (local only)
donors/
tmp/rehearsal-gateway-db/
tmp/rehearsal-gateway-backup/
# Stale build artifacts at repo root from manual go run
/dev
/merge_hetzner_into_gateway

# Local Claude Code agent state (session locks, project-local skills, etc.)
.claude/
