.semrel/

# Log files
*.log
*_logs.txt
_aggregator-*.txt
_operator-*.txt
*.zip

# PR comment output files
pr-comments-*.json

# Environment files
.env.test
.env.local

# Claude Code settings (machine-local paths and user-specific permissions)
.claude/settings.json
.claude/settings.local.json

# Ignore the file/folder that is constantly added by Cursor
EigenLayer-AVS

# VS Code workspace files
*.code-workspace
