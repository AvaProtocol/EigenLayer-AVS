# Compiler files
cache/
out/
.gocache/

# Ignores development broadcast logs
!/broadcast
/broadcast/*/31337/
/broadcast/**/dry-run/

# Dotenv file
.env
*.env
.env*

# binary
ap-avs

.DS_Store
node_modules

# Ignores operator configuration files at root
operator.yaml
metadata.json

# Ignores yaml configuration files in the config directory.
# Whitelist the shared deployment configs that ship inside the Docker
# image (Railway + rehearsal) and the .example.yaml templates that
# document the file shapes. Operator-/developer-specific configs
# (e.g. `aggregator.yaml`, `operator.yaml`, `gateway-dev.yaml`,
# `worker-*-dev.yaml`) stay ignored — they typically carry testnet
# credentials that should not land in git. Copy the matching
# `*.example.yaml` and fill in the placeholders to bootstrap one.
config/*.yaml
!config/*.example.yaml
!config/*-railway.yaml
!config/*-rehearsal.yaml
# config/archived/ holds documentation templates (the pre-Railway
# *.example.yaml files, tracked via the whitelist below) plus any
# historical real-value configs preserved verbatim. Those real-value
# files are typically symlinks to a gitignored secrets-sync directory;
# committing the symlink would leak the local filesystem path. Ignore
# everything in archived/ by default; only the *.example.yaml
# templates are tracked.
config/archived/*.yaml
!config/archived/*.example.yaml

contracts/script/output*

contracts/broadcast/
alias-ecdsa.key.json

keys/

# BadgerDB database files (runtime data)
cmd/data/
**/badger/
*.vlog
DISCARD
KEYREGISTRY
MANIFEST

